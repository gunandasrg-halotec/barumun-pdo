FROM php:8.4-cli

# System dependencies
RUN apt-get update && apt-get install -y \
    git curl zip unzip libpq-dev libpng-dev libzip-dev \
    && docker-php-ext-install pdo pdo_pgsql gd bcmath zip \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Buat scaffold Laravel 13 penuh di image layer (di-cache, hanya rebuild jika Dockerfile berubah)
# Ini mengatasi ketiadaan composer.json di repo
RUN composer create-project laravel/laravel /var/www/api \
    --prefer-dist --no-progress --no-interaction --quiet \
    && cd /var/www/api && composer require laravel/sanctum --no-interaction --quiet

WORKDIR /var/www/api

# Copy kode custom kita ke dalam scaffold
# Saat docker compose up, direktori ini di-override oleh bind mount dari host
COPY apps/api/app/ ./app/
COPY apps/api/database/ ./database/
COPY apps/api/routes/api.php ./routes/api.php
COPY apps/api/bootstrap/app.php ./bootstrap/app.php
COPY apps/api/.env.example .env.example

# Entrypoint: handle migrasi & start server
COPY docker/api/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8000
ENTRYPOINT ["/entrypoint.sh"]
