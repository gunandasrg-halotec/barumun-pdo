APP_NAME="PDO System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta

# ── Database ──────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=pdo_local
DB_USERNAME=pdo_user
DB_PASSWORD=secret

# ── Cache & Queue (Redis) ─────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── Sanctum (JWT via Cookie) ──────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost

# ── AWS S3 (untuk upload bukti transaksi) ─────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-3
AWS_BUCKET=pdo-barumunpalma-dev
AWS_URL=

# Untuk local development tanpa S3, gunakan disk lokal:
# FILESYSTEM_DISK=local

# ── WhatsApp Gateway ──────────────────────────────────
# Dikonfigurasi via Admin UI, bukan di .env
# Nilai disimpan di tabel system_settings

# ── Payroll Internal API ──────────────────────────────
PAYROLL_INTERNAL_API_BASE_URL=
PAYROLL_INTERNAL_API_TOKEN=

# ── Logging ───────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Mail (Mailpit untuk local dev) ────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null

# ── Sentry (Error tracking, isi di staging/production) ─
SENTRY_LARAVEL_DSN=
